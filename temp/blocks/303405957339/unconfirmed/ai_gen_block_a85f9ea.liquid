      "id": "products_limit",
      "label": "Products to show",
      "min": 4,
      "max": 20,
      "step": 4,
      "default": 8
    },
    {
      "type": "inline_richtext",
      "id": "button_text",
      "label": "Button text",
      "default": "Add to Cart"
    },
    {
      "type": "header",
