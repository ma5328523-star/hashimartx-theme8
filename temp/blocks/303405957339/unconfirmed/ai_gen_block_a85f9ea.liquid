{% doc %}
  @prompt
    Create a Neon Product Grid section with a luxury black background. Each product card should have a neon glow border effect (cyan/purple neon colors), glassmorphism card style with frosted glass background, smooth hover animations with neon glow intensifying on hover, product image, title, price, and an Add to Cart button with neon styling. The grid should be fully responsive (4 columns desktop, 2 tablet, 1 mobile). Use CSS variables for neon colors for easy customization.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-neon-product-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    --ai-neon-cyan-{{ ai_gen_id }}: {{ block.settings.neon_cyan }};
    --ai-neon-purple-{{ ai_gen_id }}: {{ block.settings.neon_purple }};
    --ai-neon-pink-{{ ai_gen_id }}: {{ block.settings.neon_pink }};
  }

  .ai-neon-product-grid__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-neon-product-grid__heading-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin-bottom: 40px;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 700;
  }

  .ai-neon-product-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-neon-product-card-{{ ai_gen_id }} {
    position: relative;
    background: {{ block.settings.card_background }};
    backdrop-filter: blur({{ block.settings.blur_strength }}px);
    -webkit-backdrop-filter: blur({{ block.settings.blur_strength }}px);
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    border: {{ block.settings.border_width }}px solid var(--ai-neon-cyan-{{ ai_gen_id }});
    box-shadow: 0 0 {{ block.settings.glow_intensity }}px var(--ai-neon-cyan-{{ ai_gen_id }}),
                inset 0 0 20px rgba(255, 255, 255, 0.05);
    transition: all {{ block.settings.animation_duration }}s ease;
    overflow: hidden;
  }

  .ai-neon-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
    border-color: var(--ai-neon-purple-{{ ai_gen_id }});
    box-shadow: 0 0 {{ block.settings.glow_intensity | times: 2 }}px var(--ai-neon-purple-{{ ai_gen_id }}),
                0 0 {{ block.settings.glow_intensity | times: 1.5 }}px var(--ai-neon-cyan-{{ ai_gen_id }}),
                inset 0 0 30px rgba(255, 255, 255, 0.1);
  }

  .ai-neon-product-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: 16px;
    background: rgba(255, 255, 255, 0.02);
  }

  .ai-neon-product-card__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform {{ block.settings.animation_duration }}s ease;
  }

  .ai-neon-product-card-{{ ai_gen_id }}:hover .ai-neon-product-card__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-neon-product-card__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-neon-product-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-neon-product-card__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-neon-product-card__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
    min-height: 2.6em;
  }

  .ai-neon-product-card__price-{{ ai_gen_id }} {
    color: var(--ai-neon-cyan-{{ ai_gen_id }});
    font-size: {{ block.settings.price_size }}px;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .ai-neon-product-card__button-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 24px;
    background: linear-gradient(135deg, var(--ai-neon-cyan-{{ ai_gen_id }}), var(--ai-neon-purple-{{ ai_gen_id }}));
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all {{ block.settings.animation_duration }}s ease;
    box-shadow: 0 0 15px rgba(0, 255, 255, 0.3);
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .ai-neon-product-card__button-{{ ai_gen_id }}:hover {
    box-shadow: 0 0 30px var(--ai-neon-cyan-{{ ai_gen_id }}),
                0 0 20px var(--ai-neon-purple-{{ ai_gen_id }});
    transform: translateY(-2px);
  }

  .ai-neon-product-grid__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.heading_color }};
    font-size: 18px;
    opacity: 0.6;
  }

  @media screen and (max-width: 989px) {
    .ai-neon-product-grid__grid-{{ ai_gen_id }} {
      {% if block.settings.columns_tablet == '1' %}
        grid-template-columns: 1fr;
      {% else %}
        grid-template-columns: repeat(2, 1fr);
      {% endif %}
    }

    .ai-neon-product-grid__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-neon-product-grid__grid-{{ ai_gen_id }} {
      {% if block.settings.columns_mobile == '1' %}
        grid-template-columns: 1fr;
      {% else %}
        grid-template-columns: repeat(2, 1fr);
      {% endif %}
    }

    .ai-neon-product-grid__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-neon-product-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<neon-product-grid-{{ ai_gen_id }} class="ai-neon-product-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-neon-product-grid__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-neon-product-grid__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.collection != blank %}
      <div class="ai-neon-product-grid__grid-{{ ai_gen_id }}">
        {% for product in block.settings.collection.products limit: block.settings.products_limit %}
          <div class="ai-neon-product-card-{{ ai_gen_id }}">
            <div class="ai-neon-product-card__image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-neon-product-card__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="ai-neon-product-card__image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-neon-product-card__content-{{ ai_gen_id }}">
              <h3 class="ai-neon-product-card__title-{{ ai_gen_id }}">{{ product.title }}</h3>
              <div class="ai-neon-product-card__price-{{ ai_gen_id }}">{{ product.price | money }}</div>
              <a href="{{ product.url }}" class="ai-neon-product-card__button-{{ ai_gen_id }}">
                {{ block.settings.button_text }}
              </a>
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-neon-product-grid__empty-state-{{ ai_gen_id }}">
        Select a collection to display products
      </div>
    {% endif %}
  </div>
</neon-product-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class NeonProductGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-neon-product-card-{{ ai_gen_id }}');
        this.setupAnimations();
      }

      setupAnimations() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              setTimeout(() => {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
              }, index * 100);
              observer.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.1
        });

        this.cards.forEach((card) => {
          card.style.opacity = '0';
          card.style.transform = 'translateY(30px)';
          card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
          observer.observe(card);
        });
      }
    }

    customElements.define('neon-product-grid-{{ ai_gen_id }}', NeonProductGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Neon product grid",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
