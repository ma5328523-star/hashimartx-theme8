<section class="main-product" data-section-type="main-product">
  <div class="product-container">
    <div class="product-gallery">
      <div class="gallery-main">
        {% if product.featured_image %}
          <img 
            id="mainImage" 
            src="{{ product.featured_image | img_url: '1024x' }}" 
            alt="{{ product.title }}"
            loading="lazy"
            class="main-product-image"
          >
        {% endif %}
      </div>

      {% if product.images.size > 1 %}
        <div class="gallery-thumbs">
          {% for image in product.images limit: 5 %}
            <button 
              class="thumb-item {% if image == product.featured_image %}active{% endif %}"
              data-src="{{ image | img_url: '1024x' }}"
              aria-label="Product image {{ forloop.index }}"
            >
              <img src="{{ image | img_url: '200x' }}" alt="Product thumbnail">
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="product-details">
      {% if section.settings.show_vendor %}
        <span class="product-vendor">{{ product.vendor }}</span>
      {% endif %}

      <h1 class="product-title">{{ product.title }}</h1>

      <div class="product-price-block">
        <span class="product-price">{{ product.price | money }}</span>
        {% if product.compare_at_price %}
          <span class="product-original-price">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>

      {% if product.rating != blank %}
        <div class="product-rating">
          <span class="rating-stars">★★★★★</span>
          <span class="rating-text">({{ product.reviews_count }} reviews)</span>
        </div>
      {% endif %}

      <form method="post" action="/cart/add" class="product-form">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        {% for option in product.options_with_values %}
          <fieldset class="variant-group">
            <legend class="variant-label">{{ option.name }}</legend>
            <div class="variant-options">
              {% for value in option.values %}
                <label class="variant-swatch">
                  <input 
                    type="radio" 
                    name="options[{{ option.name }}]" 
                    value="{{ value }}"
                    {% if option.selected_value == value %}checked{% endif %}
                  >
                  <span class="swatch-inner" style="background-color: {{ value | downcase | strip }};" title="{{ value }}">
                    {{ value }}
                  </span>
                </label>
              {% endfor %}
            </div>
          </fieldset>
        {% endfor %}

        {% if section.settings.show_quantity %}
          <div class="quantity-selector">
            <label for="quantity">Quantity</label>
            <div class="quantity-input">
              <button type="button" class="qty-btn qty-minus">−</button>
              <input type="number" id="quantity" name="quantity" value="1" min="1" class="qty-value">
              <button type="button" class="qty-btn qty-plus">+</button>
            </div>
          </div>
        {% endif %}

        <button type="submit" class="button button-primary button-add-to-cart">
          {{ section.settings.button_text }}
        </button>
      </form>

      {% if section.settings.show_description %}
        <div class="product-description">
          {{ product.description }}
        </div>
      {% endif %}

      <div class="product-meta">
        <span class="meta-item">✓ Premium Quality</span>
        <span class="meta-item">✓ Free Shipping</span>
        <span class="meta-item">✓ 30-Day Returns</span>
      </div>
    </div>
  </div>
</section>

<style>
  .main-product {
    padding: 3rem 1.5rem;
  }

  .product-container {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 3rem;
    max-width: 1400px;
    margin: 0 auto;
    align-items: start;
  }

  .product-gallery {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .gallery-main {
    border-radius: 24px;
    overflow: hidden;
    background: #f9f9f9;
  }

  .main-product-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    cursor: zoom-in;
    transition: transform 0.3s ease;
  }

  .main-product-image:hover {
    transform: scale(1.05);
  }

  .gallery-thumbs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.75rem;
  }

  .thumb-item {
    border: 2px solid transparent;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.2s ease;
    background: none;
    padding: 0;
  }

  .thumb-item:hover,
  .thumb-item.active {
    border-color: #111;
  }

  .thumb-item img {
    width: 100%;
    height: 120px;
    object-fit: cover;
    display: block;
  }

  .product-details {
    padding: 1rem 0;
  }

  .product-vendor {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #555;
    margin-bottom: 0.75rem;
  }

  .product-title {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.1;
  }

  .product-price-block {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .product-price {
    font-size: 1.8rem;
    font-weight: 700;
  }

  .product-original-price {
    font-size: 1rem;
    color: #999;
    text-decoration: line-through;
  }

  .product-rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .rating-stars {
    color: #ffc107;
  }

  .rating-text {
    color: #555;
  }

  .product-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .variant-group {
    border: none;
    padding: 0;
    margin: 0;
  }

  .variant-label {
    display: block;
    margin-bottom: 0.75rem;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .variant-options {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .variant-swatch {
    position: relative;
    cursor: pointer;
  }

  .variant-swatch input {
    display: none;
  }

  .swatch-inner {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 1rem;
    border: 2px solid #ddd;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
    min-width: 60px;
    background-color: #f9f9f9;
  }

  .variant-swatch input:checked + .swatch-inner {
    border-color: #111;
    background-color: #111;
    color: #fff;
  }

  .quantity-selector {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .quantity-selector label {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .quantity-input {
    display: flex;
    border: 1px solid #ddd;
    border-radius: 10px;
    overflow: hidden;
    width: fit-content;
  }

  .qty-btn {
    width: 44px;
    border: none;
    background: #f9f9f9;
    cursor: pointer;
    font-size: 1.2rem;
    transition: background 0.2s ease;
  }

  .qty-btn:hover {
    background: #e8e8e8;
  }

  .qty-value {
    width: 60px;
    text-align: center;
    border: none;
    background: transparent;
    font-weight: 600;
    padding: 0;
  }

  .qty-value::-webkit-outer-spin-button,
  .qty-value::-webkit-inner-spin-button {
    display: none;
  }

  .button-add-to-cart {
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 700;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .button-add-to-cart:hover {
    background: #333;
  }

  .product-description {
    margin: 1.5rem 0;
    padding: 1.5rem 0;
    border-top: 1px solid #e8e8e8;
    border-bottom: 1px solid #e8e8e8;
    color: #444;
    line-height: 1.8;
  }

  .product-meta {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    color: #555;
    font-size: 0.95rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
  }

  @media (max-width: 768px) {
    .product-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .gallery-thumbs {
      grid-template-columns: repeat(4, 1fr);
    }

    .product-title {
      font-size: 1.8rem;
    }

    .product-price {
      font-size: 1.4rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const thumbs = document.querySelectorAll('.thumb-item');
    const mainImage = document.getElementById('mainImage');

    thumbs.forEach(thumb => {
      thumb.addEventListener('click', function() {
        thumbs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        mainImage.src = this.dataset.src;
      });
    });

    // Quantity selector
    const qtyMinus = document.querySelector('.qty-minus');
    const qtyPlus = document.querySelector('.qty-plus');
    const qtyValue = document.getElementById('quantity');

    if (qtyMinus && qtyPlus && qtyValue) {
      qtyMinus.addEventListener('click', () => {
        if (qtyValue.value > 1) qtyValue.value--;
      });

      qtyPlus.addEventListener('click', () => {
        qtyValue.value++;
      });
    }
  });
</script>

{% schema %}
{
  "name": "Main Product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quantity",
      "label": "Show quantity selector",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Add to cart button text",
      "default": "Add to cart"
    }
  ],
  "presets": [
    {
      "name": "Product Details"
    }
  ]
}
{% endschema %}
